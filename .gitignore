# ============================================================
# CARLOG — .gitignore
# ============================================================

# ── Dependencies ─────────────────────────────────────────────
node_modules/
backend/node_modules/
frontend/node_modules/

# ── Environment (JAMAIS commiter les secrets) ─────────────────
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example

# ── Build output ──────────────────────────────────────────────
frontend/dist/
backend/dist/
build/

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS ────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── IDE ────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

# ── PM2 ────────────────────────────────────────────────────────
.pm2/

# ── Tests / Coverage ──────────────────────────────────────────
coverage/
.nyc_output/

# ── Misc ──────────────────────────────────────────────────────
*.zip
*.tar.gz
*.tgz
.cache/
tmp/
temp/
